# ─────────────────────────────────────────────────
# LeadFactory — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────

# ── Database ──────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/leadfactory.db
# For PostgreSQL: postgresql+asyncpg://user:pass@localhost:5432/leadfactory

# ── Authentication ────────────────────────────────
# REQUIRED: Stable key for JWT signing. Without this, all tokens
# are invalidated on every server restart.
LEADFACTORY_SECRET_KEY=

# ── Task Queue (optional) ────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Stripe Billing ────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_SCALE=
STRIPE_PRICE_CREDITS_1K=
STRIPE_PRICE_CREDITS_5K=
STRIPE_PRICE_CREDITS_10K=
FRONTEND_URL=http://localhost:3000

# ── Email Enrichment API Keys ────────────────────
HUNTER_API_KEY=
ZEROBOUNCE_API_KEY=
MILLIONVERIFIER_API_KEY=

# ── SMTP Verification ────────────────────────────
SMTP_TIMEOUT=10
SMTP_HELO_DOMAIN=
SMTP_PROXY_HOST=
SMTP_PROXY_PORT=25

# ── Discovery & Search ───────────────────────────
SERPAPI_KEY=
GITHUB_TOKEN=
BING_API_KEY=
BRAVE_API_KEY=

# ── LinkedIn Enrichment ──────────────────────────
PROXYCURL_API_KEY=
LINKEDIN_PROXY_URL=

# ── Outreach Providers ───────────────────────────
INSTANTLY_API_KEY=
SMARTLEAD_API_KEY=

# ── CRM Integrations ─────────────────────────────
# HubSpot
HUBSPOT_API_KEY=

# Salesforce
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
